<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BIRTH-DATE ✨</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 50%, #ffecd2 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .survey-container {
      background: white;
      border-radius: 30px;
      padding: 40px;
      max-width: 500px;
      width: 100%;
      box-shadow: 0 20px 60px rgba(252, 182, 159, 0.4);
      position: relative;
      overflow: hidden;
    }

    .question-screen {
      display: none;
      animation: fadeSlideIn 0.5s ease-out;
    }

    .question-screen.active {
      display: block;
    }

    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateX(30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .progress-bar {
      height: 8px;
      background: #f0f0f0;
      border-radius: 10px;
      margin-bottom: 30px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #ff9a9e, #fecfef);
      border-radius: 10px;
      transition: width 0.4s ease;
    }

    .question-number {
      font-size: 14px;
      color: #ff9a9e;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .question-text {
      font-size: 24px;
      color: #5a5a5a;
      margin-bottom: 30px;
      line-height: 1.4;
    }

    .question-text .emoji {
      font-size: 32px;
      display: block;
      margin-bottom: 15px;
    }

    .options {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option {
      background: #fef6f6;
      border: 2px solid #ffe4e6;
      border-radius: 16px;
      padding: 16px 20px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .option:hover {
      background: #fff0f3;
      border-color: #ffb6c1;
      transform: translateX(5px);
    }

    .option.selected {
      background: linear-gradient(135deg, #ff9a9e, #fecfef);
      border-color: transparent;
      color: white;
    }

    .option-circle {
      width: 24px;
      height: 24px;
      border: 2px solid #ffb6c1;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.3s ease;
    }

    .option.selected .option-circle {
      background: white;
      border-color: white;
    }

    .option.selected .option-circle::after {
      content: '✓';
      color: #ff9a9e;
      font-weight: bold;
      font-size: 14px;
    }

    .option-text {
      font-size: 16px;
    }

    .nav-buttons {
      display: flex;
      justify-content: space-between;
      margin-top: 30px;
      gap: 15px;
    }

    .btn {
      padding: 14px 28px;
      border: none;
      border-radius: 25px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-back {
      background: #f5f5f5;
      color: #888;
    }

    .btn-back:hover {
      background: #eee;
    }

    .btn-next {
      background: linear-gradient(135deg, #ff9a9e, #fecfef);
      color: white;
      flex-grow: 1;
    }

    .btn-next:hover {
      transform: scale(1.02);
      box-shadow: 0 5px 20px rgba(255, 154, 158, 0.4);
    }

    .btn-next:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    /* Results screen */
    .results {
      text-align: center;
    }

    .results-emoji {
      font-size: 80px;
      margin-bottom: 20px;
      animation: bounce 1s ease infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .results-title {
      font-size: 28px;
      color: #5a5a5a;
      margin-bottom: 15px;
    }

    .results-message {
      color: #888;
      font-size: 16px;
      line-height: 1.6;
      margin-bottom: 30px;
    }

    .btn-restart {
      background: linear-gradient(135deg, #a8edea, #fed6e3);
      color: #5a5a5a;
    }

    .confetti {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      animation: confettiFall 3s ease-out forwards;
    }

    @keyframes confettiFall {
      0% {
        transform: translateY(-100px) rotate(0deg);
        opacity: 1;
      }
      100% {
        transform: translateY(400px) rotate(720deg);
        opacity: 0;
      }
    }
  </style>
</head>
<body>
  <div class="survey-container" id="surveyContainer">
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill" style="width: 0%"></div>
    </div>

    <!-- Question 1 -->
    <div class="question-screen active" data-question="1">
      <div class="question-number">Question 1 of 4</div>
      <div class="question-text">
        <span class="emoji">🌸</span>
        Which date?
      </div>
      <div class="options">
        <div class="option" data-value="friday">
          <div class="option-circle"></div>
          <span class="option-text">Friday 12/6</span>
        </div>
        <div class="option" data-value="monday">
          <div class="option-circle"></div>
          <span class="option-text">Monday 15/6</span>
        </div>
      </div>
      <div class="nav-buttons">
        <button class="btn btn-next" disabled>Next →</button>
      </div>
    </div>

    <!-- Question 2 -->
    <div class="question-screen" data-question="2">
      <div class="question-number">Question 2 of 4</div>
      <div class="question-text">
        <span class="emoji">🍰</span>
        What are we getting up to? 
      </div>
        </div>
        <div class="option" data-value="chill">
          <div class="option-circle"></div>
          <span class="option-text">🍦 something chill pls</span>
      
        <div class="option" data-value="exciting">
          <div class="option-circle"></div>
          <span class="option-text">🍫 adrenaline pls</span>
        </div>
      </div>
      <div class="nav-buttons">
        <button class="btn btn-back">← Back</button>
        <button class="btn btn-next" disabled>Next →</button>
      </div>
    </div>

    <!-- Question 3 -->
    <div class="question-screen" data-question="3">
      <div class="question-number">Question 3 of 4</div>
      <div class="question-text">
        <span class="emoji">🎨</span>
        Which color makes you happiest?
      </div>
      <div class="options">
        <div class="option" data-value="pink">
          <div class="option-circle"></div>
          <span class="option-text">💗 Soft pink</span>
        </div>
        <div class="option" data-value="blue">
          <div class="option-circle"></div>
          <span class="option-text">💙 Sky blue</span>
        </div>
        <div class="option" data-value="yellow">
          <div class="option-circle"></div>
          <span class="option-text">💛 Sunny yellow</span>
        </div>
        <div class="option" data-value="lavender">
          <div class="option-circle"></div>
          <span class="option-text">💜 Lavender</span>
        </div>
      </div>
      <div class="nav-buttons">
        <button class="btn btn-back">← Back</button>
        <button class="btn btn-next" disabled>Next →</button>
      </div>
    </div>

    <!-- Question 4 -->
    <div class="question-screen" data-question="4">
      <div class="question-number">Question 4 of 4</div>
      <div class="question-text">
        <span class="emoji">✨</span>
        to munch or to monch? 
      </div>
      <div class="options">
        <div class="option" data-value="japanese">
          <div class="option-circle"></div>
          <span class="option-text">japanese</span>
        </div>
        <div class="option" data-value="chinese">
          <div class="option-circle"></div>
          <span class="option-text">chinese</span>
        </div>
        <div class="option" data-value="italian">
          <div class="option-circle"></div>
          <span class="option-text">italian</span>
        </div>
        <div class="option" data-value="korean">
          <div class="option-circle"></div>
          <span class="option-text">korean</span>
        </div>
      </div>
      <div class="nav-buttons">
        <button class="btn btn-back">← Back</button>
        <button class="btn btn-next" disabled>Submit 🎉</button>
      </div>
    </div>

    <!-- Results -->
    <div class="question-screen" data-question="results">
      <div class="results">
        <div class="results-emoji">🎀</div>
        <h2 class="results-title">Thank you!</h2>
        <p class="results-message">
          Your answers have been recorded! You're absolutely wonderful for taking the time to complete this survey. 💕
        </p>
        <button class="btn btn-restart" onclick="restartSurvey()">Start Over 🔄</button>
      </div>
    </div>
  </div>

  <script>
    const container = document.getElementById('surveyContainer');
    const progressFill = document.getElementById('progressFill');
    const totalQuestions = 4;
    let currentQuestion = 1;
    const answers = {};

    // Handle option selection
    document.querySelectorAll('.option').forEach(option => {
      option.addEventListener('click', function() {
        const screen = this.closest('.question-screen');
        const questionNum = screen.dataset.question;
        
        // Deselect others in this question
        screen.querySelectorAll('.option').forEach(opt => opt.classList.remove('selected'));
        
        // Select this one
        this.classList.add('selected');
        answers[questionNum] = this.dataset.value;
        
        // Enable next button
        screen.querySelector('.btn-next').disabled = false;
      });
    });

    // Handle next button
    document.querySelectorAll('.btn-next').forEach(btn => {
      btn.addEventListener('click', function() {
        const currentScreen = document.querySelector('.question-screen.active');
        const currentNum = parseInt(currentScreen.dataset.question);
        
        if (currentNum < totalQuestions) {
          goToQuestion(currentNum + 1);
        } else {
          showResults();
        }
      });
    });

    // Handle back button
    document.querySelectorAll('.btn-back').forEach(btn => {
      btn.addEventListener('click', function() {
        const currentScreen = document.querySelector('.question-screen.active');
        const currentNum = parseInt(currentScreen.dataset.question);
        
        if (currentNum > 1) {
          goToQuestion(currentNum - 1);
        }
      });
    });

    function goToQuestion(num) {
      document.querySelectorAll('.question-screen').forEach(screen => {
        screen.classList.remove('active');
      });
      
      const nextScreen = document.querySelector(`[data-question="${num}"]`);
      nextScreen.classList.add('active');
      
      currentQuestion = num;
      updateProgress();
    }

    function updateProgress() {
      const progress = ((currentQuestion - 1) / totalQuestions) * 100;
      progressFill.style.width = progress + '%';
    }

    function showResults() {
      document.querySelectorAll('.question-screen').forEach(screen => {
        screen.classList.remove('active');
      });
      
      const resultsScreen = document.querySelector('[data-question="results"]');
      resultsScreen.classList.add('active');
      progressFill.style.width = '100%';
      
      // Confetti effect
      createConfetti();
      
      // Log answers (you can send these to a server)
      console.log('Survey answers:', answers);
    }

    function createConfetti() {
      const colors = ['#ff9a9e', '#fecfef', '#a8edea', '#fed6e3', '#ffecd2'];
      
      for (let i = 0; i < 30; i++) {
        setTimeout(() => {
          const confetti = document.createElement('div');
          confetti.className = 'confetti';
          confetti.style.left = Math.random() * 100 + '%';
          confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
          confetti.style.animationDelay = Math.random() * 0.5 + 's';
          container.appendChild(confetti);
          
          setTimeout(() => confetti.remove(), 3000);
        }, i * 50);
      }
    }

    function restartSurvey() {
      // Clear selections
      document.querySelectorAll('.option').forEach(opt => opt.classList.remove('selected'));
      document.querySelectorAll('.btn-next').forEach(btn => btn.disabled = true);
      
      // Reset state
      Object.keys(answers).forEach(key => delete answers[key]);
      currentQuestion = 1;
      
      goToQuestion(1);
    }
  </script>
</body>
</html>
